<div class="container">
  <div class="form-page">
    <div class="form-card">
      <div class="form-card__header">
        <h1><%= t('happy_things.edit_title') %></h1>
      </div>

      <%= render "form", happy_thing: @happy_thing %>

      <div class="form-card__danger-zone">
        <%= button_to "🗑️ #{t('happy_things.delete_button')}", happy_thing_path(@happy_thing), method: :delete, class: "btn btn--danger-outline" %>
      </div>
    </div>
  </div>
</div>
