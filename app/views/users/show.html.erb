<div class="container analytics my-3">
    <div class="dash-box p-4 mx-2 mb-3 text-center">
      <h1><%= @user.name %></h1>
    </div>

    <div class="d-flex justify-content-center mt-3">
      <% if @user.emoji.present? %>
        <div class="d-flex align-items-center justify-content-center pb-3" 
             style="font-size: 8rem;">
          <%= @user.emoji %>
        </div>
      <% end %>
    </div>

    <div class="dash-box p-4 mx-2 mb-3">
      <h2><%= t('profile.happy_count') %></h2>
        <div class="happy-count d-flex justify-content-center">
          <%= @happy_count %>
        </div>
    </div>

    <div class="analytics-container dash-box p-4 mx-2 my-3">
      <h2><%= t('analytics.happylytics') %></h2>
      <h3 class="mt-2"><%= t('analytics.most_used_words_year') %></h3>
        <% if @words_for_wordcloud.present? %>
          <div class="word-cloud">
            <% @words_for_wordcloud.each do |word, frequency| %>
              <%= content_tag :span, word.capitalize, style: "font-size: #{0.5 + frequency * 0.2}rem;" %>
            <% end %>
          </div>
        <% else %>
          <p class="opacity-50"><%= t('analytics.no_words_year') %></p>
        <% end %>
    </div>

    <div class="analytics-container dash-box p-4 mx-2 my-3">
      <h2><%= t('analytics.visited_places') %></h2>
      <p><%= t('analytics.visited_count_html', count: pluralize(@visited_places_count, 'place')) %></p>
    </div>

    <% if @markers %>
      <div class="mx-2 my-3">
        <div class="rounded-map"
          data-controller="map"
          data-map-markers-value="<%= @markers.to_json %>"
          data-map-api-key-value="<%= ENV['MAPBOX_API_KEY'].presence ||
            (Rails.env.development? || Rails.env.test? ? 'FAKE_MAPBOX_API_KEY' : nil) %>">
        </div>
      </div>
    <% end %>

    <% if @user == current_user %>
      <%= link_to t('analytics.edit_profile'), edit_user_registration_path, class: "mb-5 btn nav-link bottom-icons" %>
      <%= button_to t('analytics.logout'), destroy_user_session_path, method: :delete, class: "btn shadow mt-5" %>
    <% else %>
      <% friendship = current_user.friendships.accepted.find_by(friend_id: @user.id) %>
      <% if friendship.present? %>
        <div class="mt-5 mx-2 d-flex justify-content-end">
          <%= button_to t('analytics.remove_friend'), friendship_path(friendship), method: :delete, 
              class: "btn shadow", 
              data: { confirm: t('analytics.remove_friend_confirm', name: @user.name) } %>
        </div>
      <% end %>
    <% end %>
</div>
