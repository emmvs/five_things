<div style="font-family: sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: auto;">
  <h1 style="font-size: 24px; color: #2C3E50;">
    Hey <%= @user.name.presence || 'there' %>! <%= @user.emoji.presence || '☀️' %>
  </h1>

  <p style="font-size: 16px;">
    <%= t('user_mailer.happy_things_notification.body_html') %>
  </p>

  <p style="font-size: 16px;">
    <%= t('user_mailer.happy_things_notification.cta') %>
  </p>

  <p>
    <a href="<%= root_url %>" style="display: inline-block; padding: 10px 20px; background-color:#95B7FE; color: white; text-decoration: none; border-radius: 5px;">
      <%= t('user_mailer.happy_things_notification.button') %>
    </a>
  </p>

  <p style="font-size: 14px; color: #888;">
    <%= t('user_mailer.happy_things_notification.sign_off_html') %>
  </p>
</div>
